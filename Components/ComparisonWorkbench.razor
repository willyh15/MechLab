@using DiamondMechanics.Models
@using Microsoft.AspNetCore.Components.Forms
@rendermode InteractiveServer

<div class="comparison-shell">
    <div class="comparison-header">
        <div>
            <div class="phase-label">Comparison Workbench</div>
            <h2>Compare your movement against the pro</h2>
            <p class="phase-summary">
                Upload your own video, set an offset, then jump both videos to the same phase for a cleaner visual comparison.
            </p>
        </div>
    </div>

    <div class="comparison-controls">
        <div class="upload-card">
            <label class="upload-label">Upload your video</label>
            <InputFile OnChange="HandleFileSelected" accept="video/*" class="file-input" />
            @if (!string.IsNullOrWhiteSpace(_uploadStatus))
            {
                <div class="upload-status">@_uploadStatus</div>
            }
        </div>

        <div class="offset-card">
            <label class="upload-label" for="offsetRange">User Sync Offset: @UserOffsetSeconds.ToString("0.0")s</label>
            <input id="offsetRange"
                   type="range"
                   min="-2"
                   max="2"
                   step="0.1"
                   value="@UserOffsetSeconds"
                   @oninput="OnOffsetInput" />
            <div class="offset-actions">
                <button class="jump-btn secondary" @onclick="NudgeBack">-0.1s</button>
                <button class="jump-btn secondary" @onclick="ResetOffset">Reset</button>
                <button class="jump-btn secondary" @onclick="NudgeForward">+0.1s</button>
            </div>
        </div>
    </div>

    <div class="compare-grid">
        <div class="compare-video-panel">
            <div class="compare-label-row">
                <span class="compare-label">Pro Reference</span>
                <span class="compare-meta">@PlayerName</span>
            </div>

            <div class="video-shell">
                <video id="@ProVideoElementId" class="training-video" controls preload="metadata">
                    <source src="@ProVideoUrl" type="video/mp4" />
                    Your browser does not support the video tag.
                </video>
            </div>
        </div>

        <div class="compare-video-panel">
            <div class="compare-label-row">
                <span class="compare-label">Your Video</span>
                <span class="compare-meta">@(_hasUserVideo ? "Loaded locally" : "No video loaded yet")</span>
            </div>

            <div class="video-shell">
                @if (_hasUserVideo)
                {
                    <video id="@UserVideoElementId" class="training-video" controls preload="metadata">
                        <source src="@_userVideoUrl" type="video/mp4" />
                        Your browser does not support the video tag.
                    </video>
                }
                else
                {
                    <div class="empty-video-placeholder">
                        Upload your video to start side-by-side comparison.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="comparison-action-row">
        <button class="jump-btn" @onclick="JumpToSelectedPhase">Sync to Selected Phase</button>
        <button class="jump-btn secondary" @onclick="PlayBoth">Play Both</button>
        <button class="jump-btn secondary" @onclick="PauseBoth">Pause Both</button>
    </div>

    @if (SelectedPhase is not null)
    {
        <div class="comparison-phase-summary">
            <div class="meta-chip">
                <span>Phase</span>
                <strong>@SelectedPhase.Name</strong>
            </div>
            <div class="meta-chip">
                <span>Reference Start</span>
                <strong>@SelectedPhase.StartSeconds.ToString("0.0")s</strong>
            </div>
            <div class="meta-chip">
                <span>User Start</span>
                <strong>@GetUserStartSeconds().ToString("0.0")s</strong>
            </div>
        </div>
    }
</div>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Parameter, EditorRequired]
    public string ProVideoUrl { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string ProVideoElementId { get; set; } = "pro-video";

    [Parameter, EditorRequired]
    public string UserVideoElementId { get; set; } = "user-video";

    [Parameter]
    public string PlayerName { get; set; } = string.Empty;

    [Parameter]
    public MechanicsPhase? SelectedPhase { get; set; }

    [Parameter]
    public double UserOffsetSeconds { get; set; }

    [Parameter]
    public EventCallback<double> UserOffsetSecondsChanged { get; set; }

    [Parameter]
    public EventCallback<string> UserVideoUrlChanged { get; set; }

    [Parameter]
    public EventCallback<bool> HasUserVideoChanged { get; set; }

    private string _uploadStatus = string.Empty;
    private string _userVideoUrl = string.Empty;
    private bool _hasUserVideo;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file is null)
        {
            _uploadStatus = "No file selected.";
            return;
        }

        var maxAllowedSize = 1024L * 1024L * 250L;

        if (file.Size > maxAllowedSize)
        {
            _uploadStatus = "Video is too large. Keep it under 250 MB for now.";
            return;
        }

        using var stream = file.OpenReadStream(maxAllowedSize);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        var bytes = memory.ToArray();
        var base64 = Convert.ToBase64String(bytes);
        _userVideoUrl = $"data:{file.ContentType};base64,{base64}";
        _hasUserVideo = true;
        _uploadStatus = $"Loaded: {file.Name}";

        await UserVideoUrlChanged.InvokeAsync(_userVideoUrl);
        await HasUserVideoChanged.InvokeAsync(_hasUserVideo);
    }

    private async Task OnOffsetInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var value))
        {
            UserOffsetSeconds = value;
            await UserOffsetSecondsChanged.InvokeAsync(UserOffsetSeconds);
        }
    }

    private async Task NudgeBack()
    {
        UserOffsetSeconds = Math.Round(UserOffsetSeconds - 0.1, 1);
        await UserOffsetSecondsChanged.InvokeAsync(UserOffsetSeconds);
    }

    private async Task NudgeForward()
    {
        UserOffsetSeconds = Math.Round(UserOffsetSeconds + 0.1, 1);
        await UserOffsetSecondsChanged.InvokeAsync(UserOffsetSeconds);
    }

    private async Task ResetOffset()
    {
        UserOffsetSeconds = 0;
        await UserOffsetSecondsChanged.InvokeAsync(UserOffsetSeconds);
    }

    private double GetUserStartSeconds()
    {
        if (SelectedPhase is null)
            return 0;

        var adjusted = SelectedPhase.StartSeconds + UserOffsetSeconds;
        return Math.Max(0, adjusted);
    }

    private async Task JumpToSelectedPhase()
    {
        if (SelectedPhase is null)
            return;

        await JS.InvokeVoidAsync("diamondVideo.seekTo", ProVideoElementId, SelectedPhase.StartSeconds);

        if (_hasUserVideo)
        {
            await JS.InvokeVoidAsync("diamondVideo.seekTo", UserVideoElementId, GetUserStartSeconds());
        }
    }

    private async Task PlayBoth()
    {
        await JS.InvokeVoidAsync("diamondVideo.play", ProVideoElementId);

        if (_hasUserVideo)
        {
            await JS.InvokeVoidAsync("diamondVideo.play", UserVideoElementId);
        }
    }

    private async Task PauseBoth()
    {
        await JS.InvokeVoidAsync("diamondVideo.pause", ProVideoElementId);

        if (_hasUserVideo)
        {
            await JS.InvokeVoidAsync("diamondVideo.pause", UserVideoElementId);
        }
    }
}