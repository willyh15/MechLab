@page "/player/{Slug}"
@using DiamondMechanics.Models
@using DiamondMechanics.Components
@inject DiamondMechanics.Services.PlayerLibraryService PlayerLibrary
@inject IJSRuntime JS

<PageTitle>@(_player?.Name ?? "Player Breakdown")</PageTitle>

@if (_player is null)
{
    <div class="page-shell">
        <p>Loading player...</p>
    </div>
}
else
{
    <div class="page-shell">
        <section class="player-hero">
            <div class="player-hero-left">
                <div class="eyebrow">@_player.Level · @_player.Sport · @_player.Category</div>
                <h1>@_player.Name</h1>
                <p class="player-submeta">@_player.TeamOrSchool · @_player.Position · @_player.ThrowsOrBats</p>
                <p class="player-overview">@_player.Overview</p>
            </div>
        </section>

        <section class="section analysis-layout">
            <div class="analysis-main">
                <VideoAnalysisPanel VideoElementId="@_proVideoElementId"
                                    VideoUrl="@_player.VideoUrl"
                                    SelectedPhase="@_selectedPhase"
                                    AllPhases="@_player.Phases"
                                    OnJumpRequested="OnPhaseChanged" />
            </div>

            <aside class="analysis-sidebar">
                <div class="sidebar-card">
                    <h3>Movement Timeline</h3>
                    <PhaseTimeline Phases="@_player.Phases"
                                   SelectedPhase="@_selectedPhase"
                                   SelectedPhaseChanged="OnPhaseChanged" />
                </div>

                <div class="sidebar-card">
                    <h3>Ideal Checkpoints</h3>
                    @if (_selectedPhase is not null)
                    {
                        <ul class="checkpoint-list">
                            @foreach (var point in _selectedPhase.CoachingPoints)
                            {
                                <li>
                                    <strong>@point.Title:</strong> @point.Detail
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="sidebar-card">
                    <h3>Future Expansion</h3>
                    <ul class="feature-list">
                        <li>Auto-synced comparison scoring</li>
                        <li>Pose estimation from uploaded video</li>
                        <li>Bat or arm path tracing</li>
                        <li>Drill plans generated from detected issues</li>
                    </ul>
                </div>
            </aside>
        </section>

        <section class="section">
            <ComparisonWorkbench ProVideoUrl="@_player.VideoUrl"
                                 ProVideoElementId="@_comparisonProVideoElementId"
                                 UserVideoElementId="@_comparisonUserVideoElementId"
                                 PlayerName="@_player.Name"
                                 SelectedPhase="@_selectedPhase"
                                 UserOffsetSeconds="@_userOffsetSeconds"
                                 UserOffsetSecondsChanged="OnUserOffsetChanged" />
        </section>

        <section class="section">
            <PoseOverlayWorkbench PlayerName="@_player.Name"
                                  HeroImageUrl="@_player.HeroImageUrl"
                                  SelectedPhase="@_selectedPhase"
                                  PoseSnapshots="@_poseSnapshots"
                                  PoseSnapshotsChanged="OnPoseSnapshotsChanged" />
        </section>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private PlayerProfile? _player;
    private MechanicsPhase? _selectedPhase;

    private readonly string _proVideoElementId = "player-video";
    private readonly string _comparisonProVideoElementId = "comparison-pro-video";
    private readonly string _comparisonUserVideoElementId = "comparison-user-video";

    private double _userOffsetSeconds = 0;
    private Dictionary<string, PhasePoseSnapshot> _poseSnapshots = [];

    protected override async Task OnParametersSetAsync()
    {
        _player = await PlayerLibrary.GetPlayerBySlugAsync(Slug);
        _selectedPhase = _player?.Phases.FirstOrDefault();
        _userOffsetSeconds = 0;
        _poseSnapshots = [];
    }

    private async Task OnPhaseChanged(MechanicsPhase phase)
    {
        _selectedPhase = phase;
        await JS.InvokeVoidAsync("diamondVideo.seekTo", _proVideoElementId, phase.StartSeconds);
        StateHasChanged();
    }

    private Task OnUserOffsetChanged(double value)
    {
        _userOffsetSeconds = value;
        return Task.CompletedTask;
    }

    private Task OnPoseSnapshotsChanged(Dictionary<string, PhasePoseSnapshot> snapshots)
    {
        _poseSnapshots = snapshots;
        return Task.CompletedTask;
    }
}