@using DiamondMechanics.Models
@rendermode InteractiveServer

<div class="pose-shell">
    <div class="pose-header">
        <div class="phase-label">Pose Overlay Workbench</div>
        <h2>Mark checkpoints and compare body positions</h2>
        <p class="phase-summary">
            Select a marker, click the board to place it, then save the phase snapshot.
            This is the first step toward true sports science comparison.
        </p>
    </div>

    <div class="pose-tools-grid">
        <div class="pose-panel">
            <div class="pose-field">
                <label class="pose-label">Active Marker</label>
                <select class="pose-select" @bind="SelectedMarkerKey">
                    @foreach (var marker in MarkerKeys)
                    {
                        <option value="@marker">@marker</option>
                    }
                </select>
            </div>

            <div class="pose-actions">
                <button class="pose-btn" @onclick="SaveCurrentPhase">Save Phase Snapshot</button>
                <button class="pose-btn secondary" @onclick="LoadCurrentPhase">Load Phase Snapshot</button>
            </div>

            <div class="pose-help">
                Current phase: <strong>@(SelectedPhase?.Name ?? "None")</strong>
            </div>
        </div>

        <div class="pose-panel">
            <div class="pose-field">
                <label class="pose-label">Board Background</label>
                <select class="pose-select" @bind="_backgroundMode">
                    <option value="phase">Selected phase thumbnail</option>
                    <option value="hero">Player hero image</option>
                </select>
            </div>

            <div class="pose-actions">
                <button class="pose-btn secondary" @onclick="ClearProMarkers">Clear Pro Markers</button>
                <button class="pose-btn secondary" @onclick="ClearUserMarkers">Clear User Markers</button>
                <button class="pose-btn danger" @onclick="ClearAllMarkers">Clear All</button>
            </div>

            <div class="pose-help">
                Tip: place shoulders first, then hips, then hands and head.
            </div>
        </div>

        <div class="pose-panel">
            <div class="pose-field">
                <label class="pose-label">Phase Storage</label>
                <div class="pose-help">
                    Snapshots are stored in memory per phase right now. Later we can persist them to a database.
                </div>
            </div>

            <div class="pose-legend">
                <span class="pose-legend-item"><span class="pose-dot pro"></span> Pro markers</span>
                <span class="pose-legend-item"><span class="pose-dot user"></span> User markers</span>
            </div>
        </div>
    </div>

    <div class="pose-grid">
        <div class="pose-board-panel">
            <div class="pose-board-top">
                <span class="pose-board-label">Pro Reference</span>
                <span class="pose-board-meta">@PlayerName</span>
            </div>

            <div class="pose-board" @onclick="PlaceProMarker">
                <img src="@GetBackgroundImage()" alt="Pro reference board" />
                <svg class="pose-overlay" viewBox="0 0 100 100" preserveAspectRatio="none">
                    @foreach (var line in GetLines(ProMarkers))
                    {
                        <line x1="@line.X1" y1="@line.Y1" x2="@line.X2" y2="@line.Y2" stroke="#4ea1ff" stroke-width="0.55" />
                    }
                </svg>

                @foreach (var point in ProMarkers.Values)
                {
                    <div class="pose-marker" style="left:@($"{point.X}%"); top:@($"{point.Y}%");">
                        <div class="pose-marker-label">@point.Key</div>
                    </div>
                }
            </div>
        </div>

        <div class="pose-board-panel">
            <div class="pose-board-top">
                <span class="pose-board-label">User Reference</span>
                <span class="pose-board-meta">Your comparison board</span>
            </div>

            <div class="pose-board" @onclick="PlaceUserMarker">
                <img src="@GetBackgroundImage()" alt="User reference board" />
                <svg class="pose-overlay" viewBox="0 0 100 100" preserveAspectRatio="none">
                    @foreach (var line in GetLines(UserMarkers))
                    {
                        <line x1="@line.X1" y1="@line.Y1" x2="@line.X2" y2="@line.Y2" stroke="#f6c453" stroke-width="0.55" />
                    }
                </svg>

                @foreach (var point in UserMarkers.Values)
                {
                    <div class="pose-marker user" style="left:@($"{point.X}%"); top:@($"{point.Y}%");">
                        <div class="pose-marker-label">@point.Key</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="pose-metric-grid">
        @foreach (var metric in BuildMetrics())
        {
            <div class="metric-card">
                <h4>@metric.Title</h4>
                <div class="metric-value @metric.Severity">@metric.Value</div>
                <p>@metric.Detail</p>
            </div>
        }
    </div>
</div>

@code {
    private string _backgroundMode = "phase";

    [Parameter, EditorRequired]
    public string PlayerName { get; set; } = string.Empty;

    [Parameter]
    public string HeroImageUrl { get; set; } = string.Empty;

    [Parameter]
    public MechanicsPhase? SelectedPhase { get; set; }

    [Parameter]
    public Dictionary<string, PhasePoseSnapshot> PoseSnapshots { get; set; } = [];

    [Parameter]
    public EventCallback<Dictionary<string, PhasePoseSnapshot>> PoseSnapshotsChanged { get; set; }

    private readonly string[] MarkerKeys =
    [
        "Head",
        "LeadShoulder",
        "RearShoulder",
        "LeadHip",
        "RearHip",
        "Hands"
    ];

    private string SelectedMarkerKey { get; set; } = "Head";

    private Dictionary<string, PosePoint> ProMarkers { get; set; } = [];
    private Dictionary<string, PosePoint> UserMarkers { get; set; } = [];

    protected override void OnParametersSet()
    {
        if (SelectedPhase is not null && PoseSnapshots.TryGetValue(SelectedPhase.Id, out var snapshot))
        {
            ProMarkers = Clone(snapshot.ProPoints);
            UserMarkers = Clone(snapshot.UserPoints);
        }
    }

    private string GetBackgroundImage()
    {
        if (_backgroundMode == "hero" || SelectedPhase is null || string.IsNullOrWhiteSpace(SelectedPhase.ThumbnailUrl))
            return HeroImageUrl;

        return SelectedPhase.ThumbnailUrl;
    }

    private async Task SaveCurrentPhase()
    {
        if (SelectedPhase is null)
            return;

        PoseSnapshots[SelectedPhase.Id] = new PhasePoseSnapshot
        {
            PhaseId = SelectedPhase.Id,
            ProPoints = Clone(ProMarkers),
            UserPoints = Clone(UserMarkers)
        };

        await PoseSnapshotsChanged.InvokeAsync(PoseSnapshots);
    }

    private Task LoadCurrentPhase()
    {
        if (SelectedPhase is null)
            return Task.CompletedTask;

        if (PoseSnapshots.TryGetValue(SelectedPhase.Id, out var snapshot))
        {
            ProMarkers = Clone(snapshot.ProPoints);
            UserMarkers = Clone(snapshot.UserPoints);
        }
        else
        {
            ProMarkers = [];
            UserMarkers = [];
        }

        return Task.CompletedTask;
    }

    private Task PlaceProMarker(MouseEventArgs e)
    {
        SetMarker(ProMarkers, e);
        return Task.CompletedTask;
    }

    private Task PlaceUserMarker(MouseEventArgs e)
    {
        SetMarker(UserMarkers, e);
        return Task.CompletedTask;
    }

    private void SetMarker(Dictionary<string, PosePoint> target, MouseEventArgs e)
    {
        var width = 1000.0;
        var height = 562.5;

        var x = Math.Clamp((e.OffsetX / width) * 100.0, 0, 100);
        var y = Math.Clamp((e.OffsetY / height) * 100.0, 0, 100);

        target[SelectedMarkerKey] = new PosePoint
        {
            Key = SelectedMarkerKey,
            X = x,
            Y = y
        };
    }

    private void ClearProMarkers() => ProMarkers = [];
    private void ClearUserMarkers() => UserMarkers = [];
    private void ClearAllMarkers()
    {
        ProMarkers = [];
        UserMarkers = [];
    }

    private static Dictionary<string, PosePoint> Clone(Dictionary<string, PosePoint> source) =>
        source.ToDictionary(
            x => x.Key,
            x => new PosePoint
            {
                Key = x.Value.Key,
                X = x.Value.X,
                Y = x.Value.Y
            });

    private IEnumerable<(double X1, double Y1, double X2, double Y2)> GetLines(Dictionary<string, PosePoint> points)
    {
        foreach (var pair in new[]
        {
            ("LeadShoulder", "RearShoulder"),
            ("LeadHip", "RearHip"),
            ("RearShoulder", "RearHip"),
            ("LeadShoulder", "LeadHip"),
            ("Hands", "LeadShoulder"),
            ("Hands", "RearShoulder"),
            ("Head", "LeadShoulder"),
            ("Head", "RearShoulder")
        })
        {
            if (points.TryGetValue(pair.Item1, out var a) && points.TryGetValue(pair.Item2, out var b))
            {
                yield return (a.X, a.Y, b.X, b.Y);
            }
        }
    }

    private List<PoseMetricResult> BuildMetrics()
    {
        var results = new List<PoseMetricResult>
        {
            CompareShoulderTilt(),
            CompareHipTilt(),
            CompareTorsoStack(),
            CompareHandDistance()
        };

        return results;
    }

    private PoseMetricResult CompareShoulderTilt()
    {
        var pro = ComputeLineAngle(ProMarkers, "LeadShoulder", "RearShoulder");
        var user = ComputeLineAngle(UserMarkers, "LeadShoulder", "RearShoulder");
        return CompareAngleMetric("Shoulder Tilt", pro, user);
    }

    private PoseMetricResult CompareHipTilt()
    {
        var pro = ComputeLineAngle(ProMarkers, "LeadHip", "RearHip");
        var user = ComputeLineAngle(UserMarkers, "LeadHip", "RearHip");
        return CompareAngleMetric("Hip Tilt", pro, user);
    }

    private PoseMetricResult CompareTorsoStack()
    {
        var pro = ComputeDistance(ProMarkers, "Head", "RearHip");
        var user = ComputeDistance(UserMarkers, "Head", "RearHip");

        if (pro is null || user is null)
        {
            return MissingMetric("Torso Stack", "Place Head and RearHip on both boards.");
        }

        var diff = Math.Abs(pro.Value - user.Value);
        return new PoseMetricResult
        {
            Title = "Torso Stack",
            Value = $"{diff:0.0}",
            Detail = $"Distance delta between head and rear hip. Smaller usually means closer body stack match.",
            Severity = SeverityForDifference(diff, 4, 8)
        };
    }

    private PoseMetricResult CompareHandDistance()
    {
        var pro = ComputeDistance(ProMarkers, "Hands", "RearShoulder");
        var user = ComputeDistance(UserMarkers, "Hands", "RearShoulder");

        if (pro is null || user is null)
        {
            return MissingMetric("Hand Load Distance", "Place Hands and RearShoulder on both boards.");
        }

        var diff = Math.Abs(pro.Value - user.Value);
        return new PoseMetricResult
        {
            Title = "Hand Load Distance",
            Value = $"{diff:0.0}",
            Detail = $"Distance delta from hands to rear shoulder. Useful for comparing hand slot and load position.",
            Severity = SeverityForDifference(diff, 4, 8)
        };
    }

    private PoseMetricResult CompareAngleMetric(string title, double? proAngle, double? userAngle)
    {
        if (proAngle is null || userAngle is null)
        {
            return MissingMetric(title, "Required marker pair is missing on one or both boards.");
        }

        var diff = Math.Abs(proAngle.Value - userAngle.Value);

        return new PoseMetricResult
        {
            Title = title,
            Value = $"{diff:0.0}°",
            Detail = $"Difference between pro and user marker angle.",
            Severity = SeverityForDifference(diff, 6, 12)
        };
    }

    private static PoseMetricResult MissingMetric(string title, string detail) =>
        new()
        {
            Title = title,
            Value = "--",
            Detail = detail,
            Severity = "warn"
        };

    private static string SeverityForDifference(double value, double goodMax, double warnMax)
    {
        if (value <= goodMax) return "good";
        if (value <= warnMax) return "warn";
        return "bad";
    }

    private static double? ComputeLineAngle(Dictionary<string, PosePoint> points, string aKey, string bKey)
    {
        if (!points.TryGetValue(aKey, out var a) || !points.TryGetValue(bKey, out var b))
            return null;

        var dx = b.X - a.X;
        var dy = b.Y - a.Y;
        return Math.Atan2(dy, dx) * (180 / Math.PI);
    }

    private static double? ComputeDistance(Dictionary<string, PosePoint> points, string aKey, string bKey)
    {
        if (!points.TryGetValue(aKey, out var a) || !points.TryGetValue(bKey, out var b))
            return null;

        var dx = b.X - a.X;
        var dy = b.Y - a.Y;
        return Math.Sqrt((dx * dx) + (dy * dy));
    }
}